<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panda Profile</title>
    <!-- เพิ่มฟอนต์น่ารักๆ เพื่อความตะมุตะมิ -->
    <link href="https://fonts.googleapis.com/css2?family=Itim&display=swap" rel="stylesheet">
    <style>
        /* --- General Setup --- */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Itim', cursive, sans-serif; /* ใช้ฟอนต์น่ารัก */
        }

        body {
            background-color: #f0f4f2; /* พื้นหลังสีเทาอมเขียวอ่อนๆ อารมณ์ป่าไผ่ */
            color: #333333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            background-image: 
                radial-gradient(#e0e8e4 2px, transparent 2px),
                radial-gradient(#e0e8e4 2px, transparent 2px);
            background-size: 40px 40px;
            background-position: 0 0, 20px 20px;
        }

        /* --- Main Container (กรอบใหญ่ๆ สีขาว) --- */
        .main-container {
            background-color: #ffffff;
            width: 90%;
            max-width: 450px;
            border-radius: 30px; /* ขอบมนขึ้นให้ดูน่ารัก */
            padding: 35px 25px 45px 25px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
            text-align: center;
            border: 3px solid #f2f2f2;
            position: relative;
            z-index: 10;
        }

        /* หูแพนด้าแบบมีมิติและน่ารักขึ้น */
        .main-container::before, .main-container::after {
            content: '';
            position: absolute;
            top: -25px;
            width: 75px;
            height: 75px;
            background-color: #333333;
            border-radius: 50%;
            z-index: -1;
            /* เพิ่มวงกลมด้านในหู */
            background-image: radial-gradient(circle at center, #f5f5f5 35%, #333333 40%);
        }
        .main-container::before { left: 35px; transform: rotate(-15deg); }
        .main-container::after { right: 35px; transform: rotate(15deg); }

        /* อุ้งเท้าแพนด้าเกาะขอบล่าง */
        .paw {
            position: absolute;
            bottom: -20px;
            width: 50px;
            height: 35px;
            background-color: #333333;
            border-radius: 50px 50px 30px 30px;
            z-index: 11;
        }
        .paw::before, .paw::after, .paw-center {
            content: '';
            position: absolute;
            background-color: #ffffff;
            border-radius: 50%;
        }
        /* นิ้วเท้า */
        .paw::before { width: 12px; height: 14px; top: -5px; left: 6px; transform: rotate(-15deg); }
        .paw::after { width: 12px; height: 14px; top: -5px; right: 6px; transform: rotate(15deg); }
        .paw-center { width: 12px; height: 14px; top: -8px; left: 19px; }
        .paw-pad {
            position: absolute;
            width: 26px;
            height: 16px;
            background-color: #ffffff;
            border-radius: 50%;
            bottom: 6px;
            left: 12px;
        }
        .paw.left { left: 50px; }
        .paw.right { right: 50px; }

        h1 {
            color: #333333;
            font-size: 28px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        /* --- Image Wrapper & Dark Gray Neon Effect --- */
        .image-frame {
            position: relative;
            width: 220px;
            height: 220px; 
            margin: 0 auto 25px auto;
            border-radius: 20px;
            overflow: hidden;
            background: #fff;
            padding: 6px;
            /* เพิ่มแสงเรืองรองสีเทาเข้มรอบนอก */
            box-shadow: 0 0 20px rgba(68, 68, 68, 0.4);
        }

        /* แสงนีออน "สีเทาเข้ม" วิ่งรอบกรอบรูป */
        .image-frame::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            /* ใช้สีเทาเข้ม (#444, #555) แทนสีขาว */
            background: conic-gradient(transparent, transparent, transparent, #444444);
            animation: rotateNeon 3s linear infinite;
        }

        @keyframes rotateNeon {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .image-frame-inner {
            position: relative;
            width: 100%;
            height: 100%;
            background: #fff;
            border-radius: 14px;
            overflow: hidden;
            z-index: 1;
        }

        .image-frame-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover; 
            display: none;
        }

        .image-frame-inner img.active {
            display: block;
            animation: fadeIn 0.4s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        /* --- Buttons --- */
        .btn {
            display: block;
            width: 100%;
            background-color: #ffffff;
            color: #333333;
            border: 2px dashed #cccccc; /* ขอบปุ่มแบบเส้นประดูน่ารัก */
            padding: 14px;
            margin-bottom: 12px;
            border-radius: 20px;
            font-size: 18px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .btn:hover {
            background-color: #f9f9f9;
            transform: translateY(-2px);
        }

        /* เมื่อกด/เลือกอันไหน จะเรืองแสงและเปลี่ยนสไตล์ */
        .btn.selected {
            border: 2px solid #333333;
            background-color: #333333;
            box-shadow: 0 0 15px rgba(51, 51, 51, 0.4);
            color: #ffffff;
            font-weight: bold;
        }

        .btn-next {
            background-color: #333333;
            color: #ffffff;
            margin-top: 25px;
            border: 2px solid #333333;
            font-size: 20px;
        }
        .btn-next:hover {
            background-color: #444444;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        /* --- Pop-up & Neon Frame --- */
        .popup-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(3px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .popup-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .popup-content {
            background: #ffffff;
            padding: 40px 30px;
            border-radius: 30px;
            width: 85%;
            max-width: 350px;
            text-align: center;
            position: relative;
            /* แสงนีออนสีขาววิ่งรอบป๊อบอัพ */
            border: 3px solid #ffffff;
            box-shadow: 0 0 20px #ffffff, inset 0 0 20px #ffffff;
            animation: popupNeon 1.5s ease-in-out infinite alternate;
        }

        /* ตกแต่งป๊อบอัพให้เป็นหัวแพนด้า */
        .popup-content::before, .popup-content::after {
            content: '';
            position: absolute;
            top: -20px;
            width: 50px;
            height: 50px;
            background-color: #333333;
            border-radius: 50%;
            z-index: -1;
        }
        .popup-content::before { left: 20px; }
        .popup-content::after { right: 20px; }

        @keyframes popupNeon {
            from { box-shadow: 0 0 10px #fff, inset 0 0 10px #fff; }
            to { box-shadow: 0 0 30px #fff, inset 0 0 20px #fff; }
        }

        .popup-text {
            color: #333333;
            font-size: 22px;
            line-height: 1.5;
            margin-bottom: 25px;
        }

        .close-popup {
            background: #333333;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 15px;
            cursor: pointer;
            font-size: 18px;
            transition: transform 0.2s;
        }
        .close-popup:active {
            transform: scale(0.95);
        }

        /* --- Sparkle Effect (วิ้งๆ ตอนคลิก) --- */
        .sparkle {
            position: absolute;
            width: 10px;
            height: 10px;
            background: #ffffff;
            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
            pointer-events: none;
            animation: flyOut 0.6s ease-out forwards;
            z-index: 9999;
        }

        @keyframes flyOut {
            0% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 1; }
            100% { transform: translate(var(--mx), var(--my)) scale(0) rotate(180deg); opacity: 0; }
        }

        /* ตกแต่งใบไผ่ลอยๆ พื้นหลัง */
        .bamboo-leaf {
            position: fixed;
            font-size: 30px;
            color: rgba(100, 150, 100, 0.2);
            z-index: -2;
            pointer-events: none;
            animation: float 6s ease-in-out infinite alternate;
        }
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            100% { transform: translateY(20px) rotate(15deg); }
        }
    </style>
</head>
<body>

    <!-- ใบไผ่ตกแต่งพื้นหลัง -->
    <div class="bamboo-leaf" style="top: 10%; left: 10%;">🎋</div>
    <div class="bamboo-leaf" style="top: 70%; left: 5%; animation-delay: 1s;">🌿</div>
    <div class="bamboo-leaf" style="top: 20%; right: 10%; animation-delay: 2s;">🐾</div>
    <div class="bamboo-leaf" style="top: 80%; right: 15%; animation-delay: 1.5s;">🎋</div>

    <!-- Main Card -->
    <div class="main-container">
        <h1>🐾 Panda Space 🐾</h1>
        
        <!-- รูปทรงสี่เหลี่ยม พร้อมกรอบนีออนสีเทาเข้มวิ่ง -->
        <div class="image-frame">
            <div class="image-frame-inner">
                <img src="https://i.ibb.co/4wmcZfB2/IMG-1756.jpg" alt="Image 1" id="img1" class="active">
                <img src="https://i.ibb.co/wFZmn0hL/IMG-1757.jpg" alt="Image 2" id="img2">
            </div>
        </div>

        <!-- ปุ่มสลับรูปภาพ -->
        <button class="btn" id="btn-switch" onclick="switchImage(this)">🔄 สลับรูปภาพ</button>

        <hr style="border: 0; height: 2px; background: #eee; margin: 25px 0; border-radius: 2px;">

        <!-- ปุ่มแพลตฟอร์มต่างๆ -->
        <a href="https://www.instagram.com/sdxzwcz.x?igsh=amJlN3k4d3l6OGhx&utm_source=qr" target="_blank" class="btn plat-btn" onclick="selectBtn(this)">📸 Instagram</a>
        <a href="https://www.threads.com/@zczexx.o0?igshid=NTc4MTIwNjQ2YQ==" target="_blank" class="btn plat-btn" onclick="selectBtn(this)">🧵 Threads 1</a>
        <a href="https://www.threads.com/@xdijlan.xx?igshid=NTc4MTIwNjQ2YQ==" target="_blank" class="btn plat-btn" onclick="selectBtn(this)">🧸 Threads 2 (แอครอง)</a>

        <!-- ปุ่มหน้าต่อไป (เปิด Pop-up) -->
        <button class="btn btn-next" onclick="openPopup(this)">หน้าต่อไป ➔</button>

        <!-- อุ้งเท้าแพนด้าด้านล่าง -->
        <div class="paw left">
            <div class="paw-center"></div>
            <div class="paw-pad"></div>
        </div>
        <div class="paw right">
            <div class="paw-center"></div>
            <div class="paw-pad"></div>
        </div>
    </div>

    <!-- Pop-up Window -->
    <div class="popup-overlay" id="popup">
        <div class="popup-content">
            <div class="popup-text">
                สวัสดี กูชื่อดาเรียนครับ 011 <br><br>ยินดีที่ได้รู้จัก (ดาโนดิว่ะ) 🐼
            </div>
            <button class="close-popup" onclick="closePopup()">ปิดหน้าต่าง</button>
        </div>
    </div>

    <script>
        // ฟังก์ชันสลับรูปภาพไปมา
        function switchImage(button) {
            selectBtn(button);
            const img1 = document.getElementById('img1');
            const img2 = document.getElementById('img2');
            
            if(img1.classList.contains('active')) {
                img1.classList.remove('active');
                img2.classList.add('active');
            } else {
                img2.classList.remove('active');
                img1.classList.add('active');
            }
        }

        // ฟังก์ชันเมื่อกดเลือกปุ่มใดๆ จะเรืองแสงและเปลี่ยนสีค้างไว้
        function selectBtn(element) {
            element.classList.toggle('selected');
        }

        // ฟังก์ชันเปิดป๊อบอัพ พร้อมสลับเป็นรูปที่ 2 อัตโนมัติ
        function openPopup(button) {
            selectBtn(button);
            document.getElementById('popup').classList.add('active');
            
            // บังคับเปลี่ยนเป็นรูปที่ 2
            document.getElementById('img1').classList.remove('active');
            document.getElementById('img2').classList.add('active');
        }

        // ฟังก์ชันปิดป๊อบอัพ
        function closePopup() {
            document.getElementById('popup').classList.remove('active');
        }

        // เอฟเฟกต์วิ้งๆ (Sparkles แบบดาว) ตามจุดที่คลิกบนหน้าจอ
        document.addEventListener('click', function(e) {
            for (let i = 0; i < 6; i++) {
                const sparkle = document.createElement('div');
                sparkle.classList.add('sparkle');
                
                // กำหนดตำแหน่ง
                sparkle.style.left = (e.pageX - 5) + 'px';
                sparkle.style.top = (e.pageY - 5) + 'px';
                
                // สุ่มทิศทางและสีของวิ้งๆ
                const mx = (Math.random() - 0.5) * 120 + 'px';
                const my = (Math.random() - 0.5) * 120 + 'px';
                sparkle.style.setProperty('--mx', mx);
                sparkle.style.setProperty('--my', my);
                
                // สุ่มสีให้มีเทาเข้มปนกับขาวเพื่อให้เข้าธีม
                const colors = ['#ffffff', '#cccccc', '#555555'];
                sparkle.style.background = colors[Math.floor(Math.random() * colors.length)];
                
                document.body.appendChild(sparkle);
                
                sparkle.addEventListener('animationend', function() {
                    sparkle.remove();
            
                });
            }
        });
    </script>
</body>
</html>
